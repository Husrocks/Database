1.
SELECT employee_id,
       last_name,
       salary,
       ROUND(salary * 1.155, 0) AS [New Salary]
FROM employees;
2.
SELECT 
    UPPER(LEFT(last_name, 1)) + LOWER(SUBSTRING(last_name, 2, LEN(last_name))) AS [Last Name],
    LEN(last_name) AS [Length]
FROM employees
WHERE last_name LIKE 'A%' OR last_name LIKE 'M%'
ORDER BY last_name;


DECLARE @Letter CHAR(1);
SET @Letter = 'H';  -- Change letter here

SELECT 
    UPPER(LEFT(last_name, 1)) + LOWER(SUBSTRING(last_name, 2, LEN(last_name))) AS [Last Name],
    LEN(last_name) AS [Length]
FROM employees
WHERE last_name LIKE UPPER(@Letter) + '%'
ORDER BY last_name;

3.
SELECT last_name,
       ROUND(DATEDIFF(MONTH, hire_date, GETDATE()), 0) AS MONTHS_WORKED
FROM employees
ORDER BY MONTHS_WORKED;
4.
SELECT last_name,
       ISNULL(CAST(commission_pct AS VARCHAR(10)), 'No Commission') AS COMM
FROM employees;
5.
SELECT country_id, country_name
FROM countries

EXCEPT

SELECT c.country_id, c.country_name
FROM countries c
JOIN locations l ON c.country_id = l.country_id
JOIN departments d ON l.location_id = d.location_id;
6.
SELECT last_name AS Name, department_id
FROM employees

UNION

SELECT department_name AS Name, department_id
FROM departments;
