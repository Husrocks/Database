
USE ACCOUNTS;
GO

IF OBJECT_ID('accounts.countries','U') IS NOT NULL
  DROP TABLE accounts.countries;
GO

CREATE TABLE accounts.countries  (
    CountryID     INT IDENTITY(1,1) PRIMARY KEY,
    CountryName   NVARCHAR(100) NOT NULL,
    Continent     NVARCHAR(50),
    Capital       NVARCHAR(100),
    POP           BIGINT,            -- population
    Area_km2      BIGINT             -- area in square kilometers (example)
);
GO


